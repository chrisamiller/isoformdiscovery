/*
 * nextflow.config
 *
 * Global configuration for the transcript-assembly pipeline.
 *
 * Profiles:
 *   ris       — WUSTL RIS cluster (LSF + Docker); include with -profile ris
 *   test      — minimal params for dry-run smoke tests (no data required)
 *   standard  — local execution (no cluster); default if no profile given
 *
 * Resource caps (max_memory, max_cpus, max_time) bound all labels declared in
 * conf/base.config via the check_max() function defined below.
 */

manifest {
    name            = 'transcript_assembly'
    author          = 'Timley Lab, WUSTL'
    description     = 'Nanopore cDNA transcript discovery, quantification, and differential isoform analysis'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// ── Parameters ────────────────────────────────────────────────────────────────

params {

    // Required inputs
    input          = null        // path to CSV samplesheet
    gtf            = null        // reference annotation GTF (Ensembl)
    fasta          = null        // reference genome FASTA
    star_sjouts    = null        // text file: one STAR SJ.out.tab path per line
    star_bams      = null        // text file: one STAR BAM/CRAM path per line

    // Output
    outdir             = './results'
    publish_dir_mode   = 'copy'

    // Shared scratch for ESPRESSO Option-C intermediates (Option C design).
    // This directory must be on a cluster filesystem accessible from all nodes.
    // It is NOT cleaned automatically — run 'rm -rf <espresso_scratch>' after
    // confirming outputs are correct.
    espresso_scratch   = null

    // Optional chromosome override.
    // null = detect from BAM @SQ headers (default).
    // Set to a comma-separated list to restrict processing, e.g.:
    //   --chromosomes 'chr1,chr2,chrX'
    chromosomes        = null

    // ESPRESSO options
    espresso_read_ratio_cutoff = 2   // passed via ext.args for rounds 2 and FSM

    // FILTER_NORMALIZE options
    filter_min_count = 5             // minimum total read count to retain a transcript

    // rMATS-long options
    rmats_delta_proportion = 0.1
    rmats_adj_pvalue       = 0.1

    // Resource caps — raise max_memory if cluster allows (ESPRESSO_Q needs 300 GB)
    max_memory     = '320.GB'
    max_cpus       = 32
    max_time       = '240.h'

    // Cluster (RIS) options — set via ris.config or command-line override
    user_group     = null
    job_group_name = null
    queue_cpu      = 'general'

    // Trace / reporting
    tracedir           = "${params.outdir}/pipeline_info"
}

// ── Process defaults ──────────────────────────────────────────────────────────

process {
    // Default shell for all scripts
    shell = ['/bin/bash', '-euo', 'pipefail']

    // Bind-mount the ESPRESSO shared-scratch directory into containers so that
    // ESPRESSO_S/C/Q can read each other's outputs across separate container runs.
    // No-op when espresso_scratch is null (dry-run / test profiles without data).
    withName: 'ESPRESSO_.*' {
        containerOptions = {
            params.espresso_scratch
                ? "-v ${params.espresso_scratch}:${params.espresso_scratch}"
                : ''
        }
    }
}

// ── Config files ──────────────────────────────────────────────────────────────
// Included HERE (before profiles) so that profile settings override base labels.

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ── Profiles ──────────────────────────────────────────────────────────────────

profiles {

    standard {
        process.executor = 'local'
        docker.enabled   = true
        params {
            max_memory = '12.GB'
            max_cpus   = 4
            max_time   = '24.h'
        }
        // ESPRESSO_C requires ≥2 threads and splits sam.list3 into task.cpus
        // pieces.  For sparse test data (< 1001 bytes per piece), keep the
        // thread count at the minimum so the file size check passes.
        process {
            withLabel: process_espresso_c {
                cpus = 2
            }
        }
    }

    ris {
        includeConfig 'conf/ris.config'

        executor {
            name      = 'lsf'
            queueSize = 200
        }

        process {
            executor       = 'lsf'
            queue          = { params.queue_cpu }
            clusterOptions = { "-a 'docker(${task.container})' -G ${params.user_group} -g ${params.job_group_name} -R 'span[hosts=1]'" }
        }
    }

    test {
        params {
            input          = "${projectDir}/assets/samplesheet_example.csv"
            outdir         = 'test_results'
            espresso_scratch = '/tmp/espresso_test'
            max_memory     = '16.GB'
            max_cpus       = 4
            max_time       = '2.h'
        }
    }
}

// ── Reporting ─────────────────────────────────────────────────────────────────

timeline {
    enabled = true
    file    = "${params.tracedir}/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.tracedir}/execution_report.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.tracedir}/execution_trace.txt"
    overwrite = true
}
dag {
    enabled   = true
    file      = "${params.tracedir}/pipeline_dag.svg"
    overwrite = true
}

// ── Helper function: cap resource requests at params.max_* ───────────────────

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: check_max() not able to use max memory: '${params.max_memory}'"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: check_max() not able to use max time: '${params.max_time}'"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "WARNING: check_max() not able to use max cpus: '${params.max_cpus}'"
            return obj
        }
    }
}
