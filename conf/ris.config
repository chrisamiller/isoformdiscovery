/*
 * conf/ris.config
 *
 * WUSTL RIS (Research Infrastructure Services) cluster parameters.
 *
 * This file sets the lab-specific values required to submit jobs via LSF
 * with Docker at RIS.  Include it via the 'ris' profile in nextflow.config.
 *
 * Override any of these at run-time with --user_group, --job_group_name, or
 * --queue_cpu on the Nextflow command line.
 */

params {
    user_group     = 'compute-timley'
    job_group_name = '/timley/nextflow'
    queue_cpu      = 'general'
}
