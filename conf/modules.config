/*
 * conf/modules.config
 *
 * Per-process publishDir settings and ext.args for the transcript-assembly
 * pipeline.  All final outputs are published under params.outdir; intermediate
 * per-chromosome ESPRESSO working directories are not published (they live on
 * params.espresso_scratch).
 */

process {

    // ── Samplesheet validation ───────────────────────────────────────────────
    withName: 'SAMPLESHEET_CHECK' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.endsWith('.csv') ? fn : null }
        ]
    }

    // ── SQANTI3 QC ──────────────────────────────────────────────────────────
    withName: 'SQANTI3_QC' {
        containerOptions = {
            if (!params.star_bams) return ''
            try {
                def firstLine = new File(params.star_bams.toString()).readLines()
                    .find { it.trim() }
                if (!firstLine) return ''
                def bamDir = new File(firstLine.trim()).parent
                return bamDir ? "-v ${bamDir}:${bamDir}" : ''
            } catch (e) { return '' }
        }
        publishDir = [
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_classification.txt'],
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_corrected.gtf'],
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_corrected.fasta'],
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_corrected.faa'],
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_corrected.genePred'],
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_corrected.gtf.cds.gff'],
            [path: { "${params.outdir}/sqanti" }, mode: params.publish_dir_mode, pattern: '*_junctions.txt']
        ]
    }

    // ── SQANTI3 ML filter ────────────────────────────────────────────────────
    withName: 'SQANTI3_FILTER' {
        publishDir = [
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: '*_MLresult_classification.txt'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: '*.filtered.gtf'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: '*_inclusion-list.txt'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: '*_TN_list.txt'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: '*_TP_list.txt'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: 'classifier_variable-importance_table.txt'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: 'randomforest.RData'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: 'testSet_*'],
            [path: { "${params.outdir}/sqanti/filter_ml_default" }, mode: params.publish_dir_mode, pattern: '*_params.txt']
        ]
    }

    // ── Ensembl transcript restoration ──────────────────────────────────────
    withName: 'RESTORE_ENSEMBL' {
        publishDir = [
            path: { "${params.outdir}/sqanti/filter_ml_default" },
            mode: params.publish_dir_mode,
            pattern: '*.ensrestore.gtf'
        ]
    }

    // ── ESPRESSO_Q round 0 per-chromosome ────────────────────────────────────
    withName: 'ESPRESSO_Q_R0' {
        publishDir = [
            [path: { "${params.outdir}/read_isoform_assignments" }, mode: params.publish_dir_mode,
             pattern: '*_compatible_isoform.tsv.gz']
        ]
        ext.args = ''
    }

    // ── ESPRESSO_Q round 2 per-chromosome ────────────────────────────────────
    withName: 'ESPRESSO_Q_R2' {
        label = 'process_espresso_requant'
        publishDir = [
            path: { "${params.outdir}/read_isoform_assignments/filtered" },
            mode: params.publish_dir_mode,
            pattern: '*_compatible_isoform.tsv.gz',
            saveAs: { fn -> fn.replace('_compatible_isoform.tsv.gz', '_compatible_isoform.filtered.tsv.gz') }
        ]
        ext.args = '--read_ratio_cutoff 2'
    }

    // ── ESPRESSO_Q FSM per-chromosome ────────────────────────────────────────
    withName: 'ESPRESSO_Q_FSM' {
        label = 'process_espresso_requant'
        publishDir = [
            path: { "${params.outdir}/read_isoform_assignments/fsm" },
            mode: params.publish_dir_mode,
            pattern: '*_compatible_isoform.tsv.gz',
            saveAs: { fn -> fn.replace('_compatible_isoform.tsv.gz', '_compatible_isoform.filtered.fsm.tsv.gz') }
        ]
        ext.args = '--read_ratio_cutoff 2'
    }

    // ── MERGE_ESPRESSO round 0 ───────────────────────────────────────────────
    withName: 'MERGE_ESPRESSO_R0' {
        ext.prefix = 'merged_N2_R0'
        publishDir = [
            [path: { "${params.outdir}/initial_assembly" }, mode: params.publish_dir_mode, pattern: 'merged_N2_R0_*.esp'],
            [path: { "${params.outdir}/initial_assembly" }, mode: params.publish_dir_mode, pattern: 'merged_N2_R0_*.gtf']
        ]
    }

    // ── MERGE_ESPRESSO FSM ───────────────────────────────────────────────────
    withName: 'MERGE_ESPRESSO_FSM' {
        ext.prefix = 'merged_fsm_N2_R2'
        publishDir = [
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode, pattern: 'merged_fsm_N2_R2_*.esp'],
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode, pattern: 'merged_fsm_N2_R2_*.gtf'],
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode, pattern: '*novel_transcripts.gtf']
        ]
    }

    // ── rMATS-long ───────────────────────────────────────────────────────────
    withName: 'RMATS_LONG' {
        publishDir = [
            path: { "${params.outdir}/rmats-long-fsm" },
            mode: params.publish_dir_mode,
            pattern: 'rmats_out'
        ]
    }

    // ── Per-sample FSM BAM assembly ──────────────────────────────────────────
    withName: 'FSM_FILTER|BAM_MERGE_INDEX' {
        containerOptions = {
            params.espresso_scratch
                ? "-v ${params.espresso_scratch}:${params.espresso_scratch}"
                : ''
        }
    }

    withName: 'BAM_MERGE_INDEX' {
        publishDir = [
            [path: { "${params.outdir}/fsm_bams" }, mode: params.publish_dir_mode, pattern: '*.bam'],
            [path: { "${params.outdir}/fsm_bams" }, mode: params.publish_dir_mode, pattern: '*.bam.bai']
        ]
    }

    // ── Filtering and normalization ──────────────────────────────────────────
    withName: 'FILTER_NORMALIZE' {
        publishDir = [
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode,
             pattern: '*.covfilt.noism.esp',
             saveAs: { fn -> fn.replace('.covfilt.noism.esp', '_filtered.tsv') }],
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode,
             pattern: '*.covfilt.noism.cpm.esp',
             saveAs: { fn -> fn.replace('.covfilt.noism.cpm.esp', '_filtered_cpm.tsv') }],
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode,
             pattern: '*.covfilt.noism.tpm.esp',
             saveAs: { fn -> fn.replace('.covfilt.noism.tpm.esp', '_filtered_tpm.tsv') }],
            [path: { "${params.outdir}" }, mode: params.publish_dir_mode,
             pattern: '*.covfilt.noism.gtf',
             saveAs: { fn -> fn.replace('.covfilt.noism.gtf', '.filtered.gtf') }]
        ]
    }
}
