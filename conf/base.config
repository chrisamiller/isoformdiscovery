/*
 * conf/base.config
 *
 * Default resource labels for the transcript-assembly pipeline.
 *
 * Standard nf-core labels (process_single through process_high) are kept
 * for lightweight processes.  Additional labels cover ESPRESSO's extreme
 * memory requirements and the other compute-heavy steps.
 *
 * All values pass through check_max() so they are capped by the
 * params.max_* values declared in nextflow.config.
 */

process {

    // ── Standard nf-core labels ──────────────────────────────────────────────

    withLabel: process_single {
        cpus   = { check_max( 1,                  'cpus'   ) }
        memory = { check_max( 6.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_low {
        cpus   = { check_max( 2,                   'cpus'   ) }
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h  * task.attempt,  'time'   ) }
    }
    withLabel: process_medium {
        cpus   = { check_max( 6,                   'cpus'   ) }
        memory = { check_max( 36.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h * task.attempt,  'time'   ) }
    }
    withLabel: process_high {
        cpus   = { check_max( 12,                   'cpus'   ) }
        memory = { check_max( 120.GB * task.attempt, 'memory' ) }
        time   = { check_max( 72.h  * task.attempt,  'time'   ) }
    }

    // ── ESPRESSO-specific labels ─────────────────────────────────────────────

    // ESPRESSO_S: per-chromosome signal detection (8 threads, 96 GB)
    withLabel: process_espresso_s {
        cpus   = { check_max( 8,     'cpus'   ) }
        memory = { check_max( 96.GB, 'memory' ) }
        time   = { check_max( 48.h,  'time'   ) }
    }

    // ESPRESSO_C: per-chromosome × per-sample correction (8 threads, 72 GB)
    withLabel: process_espresso_c {
        cpus   = { check_max( 8,     'cpus'   ) }
        memory = { check_max( 72.GB, 'memory' ) }
        time   = { check_max( 24.h,  'time'   ) }
    }

    // ESPRESSO_Q round 0: first quantification — single-threaded, very high memory
    withLabel: process_espresso_q {
        cpus   = { check_max( 1,      'cpus'   ) }
        memory = { check_max( 300.GB, 'memory' ) }
        time   = { check_max( 96.h,   'time'   ) }
    }

    // ESPRESSO_Q rounds 2 and FSM: re-quantification with filtered inputs
    withLabel: process_espresso_requant {
        cpus   = { check_max( 8,      'cpus'   ) }
        memory = { check_max( 200.GB, 'memory' ) }
        time   = { check_max( 72.h,   'time'   ) }
    }

    // ── Other pipeline-specific labels ───────────────────────────────────────

    // BAM splitting: one job per sample (2 threads, 8 GB)
    withLabel: process_bam_split {
        cpus   = { check_max( 2,    'cpus'   ) }
        memory = { check_max( 8.GB, 'memory' ) }
        time   = { check_max( 8.h,  'time'   ) }
    }

    // Merge operations: ESPRESSO output merge and BAM merge/index
    withLabel: process_merge {
        cpus   = { check_max( 4,     'cpus'   ) }
        memory = { check_max( 16.GB, 'memory' ) }
        time   = { check_max( 12.h,  'time'   ) }
    }

    // FSM filtering: remove_nonfsm_data.pl
    withLabel: process_fsm_filter {
        cpus   = { check_max( 2,     'cpus'   ) }
        memory = { check_max( 16.GB, 'memory' ) }
        time   = { check_max( 24.h,  'time'   ) }
    }

    // SQANTI3 QC and ML filter
    withLabel: process_sqanti3 {
        cpus   = { check_max( 8,     'cpus'   ) }
        memory = { check_max( 32.GB, 'memory' ) }
        time   = { check_max( 24.h,  'time'   ) }
    }

    // rMATS-long differential isoform analysis
    withLabel: process_rmats {
        cpus   = { check_max( 16,    'cpus'   ) }
        memory = { check_max( 64.GB, 'memory' ) }
        time   = { check_max( 48.h,  'time'   ) }
    }

    // ── Error strategy ───────────────────────────────────────────────────────
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'
}
